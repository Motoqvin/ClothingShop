@using ClothingStoreApp.Infrastructure.Data
@using Microsoft.AspNetCore.Identity
@inject UserManager<User> UserManager
@inject IHttpContextAccessor HttpContextAccessor
@inject StoreDbContext DbContext

@{
    var user = await UserManager.GetUserAsync(HttpContextAccessor.HttpContext?.User!);
    string? avatarPath = null;

    if (user != null)
    {
        var userProfile = DbContext.Users.FirstOrDefault(u => u.Email == user.Email);
        avatarPath = userProfile?.Avatar;
    }

    string avatarUrl = string.IsNullOrEmpty(avatarPath)
    ? "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS8oghbsuzggpkknQSSU-Ch_xep_9v3m6EeBQ&s"
    : "/" + avatarPath;

    bool isAuthenticated = base.User.Identity?.IsAuthenticated ?? false;
}

<!DOCTYPE html>
<html lang="en" class="h-100">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>🧥 ClothingStore</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <style>
        html,
        body {
            height: 100%;
            font-family: 'Inter', sans-serif;
            background-color: #f1f3f5;
            color: #212529;
        }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
        }

        .navbar-brand {
            font-weight: 600;
            font-size: 1.5rem;
        }

        .navbar-nav .nav-link {
            font-weight: 500;
            padding: 0.5rem 1rem;
            transition: color 0.3s ease, background-color 0.3s ease;
        }

        .navbar-nav .nav-link:hover {
            color: #f8f9fa;
            background-color: #495057;
            border-radius: 0.25rem;
        }

        .dropdown-menu {
            border-radius: 0.5rem;
            border: none;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        }

        .dropdown-item:hover {
            background-color: #f1f3f5;
            color: #343a40;
        }

        footer {
            background-color: #343a40;
            color: #ced4da;
            padding: 1rem 0;
            font-size: 0.9rem;
            box-shadow: 0 -2px 5px rgba(0, 0, 0, 0.1);
        }

        .rounded-circle {
            border: 2px solid #dee2e6;
        }

        a {
            text-decoration: none;
        }

        .btn {
            transition: all 0.3s ease-in-out;
        }

        .btn:hover {
            transform: scale(1.02);
        }

        .nav-link.text-warning {
            font-weight: 600;
        }
    </style>

</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Welcome">🧥 ClothingStore</a>
                @if (isAuthenticated)
                {
                    <ul class="navbar-nav ms-auto d-flex align-items-center">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown"
                                role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="@avatarUrl" alt="Avatar" class="rounded-circle"
                                    style="width: 32px; height: 32px; object-fit: cover;" />
                                <span>@User.Identity?.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li><a class="dropdown-item" asp-controller="Identity" asp-action="MyInfo">👤 My Profile</a>
                                </li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li><a class="dropdown-item text-danger" asp-controller="Identity" asp-action="Logout">🚪
                                        Logout</a></li>
                            </ul>
                            @if (User.IsInRole("Admin"))
                            {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">⚙️ Admin Panel</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Admin" asp-action="Dashboard">📊 Dashboard</a>
                            </li>
                        }
                        </li>
                    </ul>
                }

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto">
                    </ul>

                    @if (isAuthenticated == false)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Identity" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Identity"
                                    asp-action="Registration">Registration</a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">🛍️Shop</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cart" asp-action="Index">🛒Cart</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="GetOrders">📃Orders</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="container my-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3" role="alert" id="flashAlert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3" role="alert" id="flashAlert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="text-center mt-auto">
        <div class="container">
            <small>&copy; @DateTime.Now.Year - ClothingStoreApp. All rights reserved.</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script
        src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        setTimeout(function () {
            document.querySelectorAll('#flashAlert').forEach(function (el) {
                bootstrap.Alert.getOrCreateInstance(el).close();
            });
        }, 4000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
