@inject IOrdersRepository ordersRepository
@using System.Security.Claims

@{
    ViewData["Title"] = "Your Orders";

    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var orders = ordersRepository.GetAll(userId ?? string.Empty);
}

<style>

.hero{
    background:linear-gradient(135deg,#212529,#495057);
    color:white;
    border-radius:22px;
    padding:3rem;
    text-align:center;
    margin-bottom:2rem;
}

.order-card{
    border:none;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
    transition:.3s;
}

.order-card:hover{
    transform:translateY(-4px);
    box-shadow:0 18px 35px rgba(0,0,0,.12);
}

.order-id{
    font-size:1.3rem;
    font-weight:700;
}

.order-date{
    color:#6c757d;
}

.order-price{
    color:#0d6efd;
    font-size:1.5rem;
    font-weight:700;
}

.btn-modern{
    border-radius:12px;
    font-weight:600;
    padding:10px 16px;
}

</style>

<div class="hero">

    <h1>Your Orders</h1>

    <p class="mb-0">
        Review your previous purchases.
    </p>

</div>

<div class="d-flex justify-content-between align-items-center mb-4">

    <h3>
        @orders.Count() Orders
    </h3>

    <a asp-controller="Cart"
       asp-action="Index"
       class="btn btn-dark btn-modern">

        <i class="bi bi-cart-plus"></i>

        New Order

    </a>

</div>

@if(!orders.Any())
{

<div class="alert alert-info text-center p-5 rounded-4">

    <h4>No Orders Yet</h4>

    <p class="mb-4">
        Your orders will appear here after checkout.
    </p>

    <a asp-controller="Home"
       asp-action="Index"
       class="btn btn-dark btn-modern">

        Start Shopping

    </a>

</div>

}
else
{

<div class="row">

@foreach(var order in orders)
{

<div class="col-lg-6 mb-4">

<div class="card order-card h-100">

<div class="card-body">

<div class="d-flex justify-content-between align-items-start">

<div>

<div class="order-id">

Order #@order.Id

</div>

<div class="order-date">

<i class="bi bi-calendar-event"></i>

@order.Date.ToString("dd MMM yyyy • HH:mm")

</div>

</div>

<div class="order-price">

$@order.TotalPrice

</div>

</div>

<hr>

<div class="d-flex justify-content-between">

<a asp-controller="Order"
   asp-action="@order.Id"
   class="btn btn-outline-dark btn-modern">

    <i class="bi bi-eye"></i>

    View Details

</a>

<button class="btn btn-outline-danger btn-modern"
        onclick="DeleteOrder(@order.Id)">

    <i class="bi bi-trash"></i>

    Delete

</button>

</div>

</div>

</div>

</div>

}

</div>

}

<script>
    function DeleteOrder(orderId) {
        if (!confirm("Are you sure you want to delete this order?")) return;

        fetch(`/Order/${orderId}`, {
            method: 'DELETE'
        })
        .then(response => {
            if (response.ok) {
                window.location.reload();
            } else {
                alert("Failed to delete order.");
            }
        });
    }
</script>
