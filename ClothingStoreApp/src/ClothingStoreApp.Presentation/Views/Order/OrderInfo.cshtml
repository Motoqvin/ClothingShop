@model Order?

@using System.Globalization
@inject IProductsRepository productRepository

@{
    ViewData["Title"] = "Order Details";
    var orderId = Model?.Id ?? 0;
    var storeProducts = productRepository.GetAll();
}

<style>
    .hero{
        background:linear-gradient(135deg,#212529,#495057);
        color:white;
        border-radius:22px;
        padding:3rem;
        text-align:center;
        margin-bottom:2rem;
    }

    .section-card{
        border:none;
        border-radius:20px;
        box-shadow:0 10px 30px rgba(0,0,0,.08);
    }

    .product-card{
        border:none;
        border-radius:18px;
        box-shadow:0 8px 20px rgba(0,0,0,.07);
        transition:.3s;
    }

    .product-card:hover{
        transform:translateY(-3px);
        box-shadow:0 15px 30px rgba(0,0,0,.12);
    }

    .summary{
        position:sticky;
        top:20px;
    }

    .btn-modern{
        border-radius:12px;
        font-weight:600;
    }
</style>

@if(Model != null)
{
    <div class="hero">
        <h1>Order #@Model.Id</h1>
        <p class="mb-0">@Model.Date.ToString("dd MMM yyyy • HH:mm")</p>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card section-card mb-4">
                <div class="card-body">
                    <h4 class="mb-4"><i class="bi bi-plus-circle"></i>Add Product</h4>
                    <form id="ProductForm" class="row g-3">
                        <div class="col-md-7">
                            <select id="productSelect" class="form-select" required>
                                <option selected disabled>Select Product</option>
                                @foreach(var product in storeProducts)
                                {
                                    <option value="@product.Id">@product.Name — $@product.Price</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <input id="quantity"
                                class="form-control"
                                value="1"
                                type="number"
                                min="1">
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-dark w-100 btn-modern">
                                <i class="bi bi-cart-plus"></i>Add
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            <h3 class="mb-3">Products</h3>
            <div id="productList"></div>
        </div>
        <div class="col-lg-4">
            <div class="card section-card summary">
                <div class="card-body">
                    <h3>Order Summary</h3>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span>Order ID</span>
                        <strong>#@Model.Id</strong>
                    </div>
                    <div class="d-flex justify-content-between mt-3">
                        <span>Total</span>
                        <strong id="orderTotal" class="text-primary fs-4">
                            $@Model.TotalPrice.ToString("F2", CultureInfo.InvariantCulture)
                        </strong>
                    </div>

                    <button id="saveOrderBtn" class="btn btn-dark w-100 mt-4 btn-modern">
                        <i class="bi bi-check-circle"></i>Finish
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger text-center">Order not found.</div>
}

@section Scripts {
  <script>
    const orderId = @orderId;
    document.addEventListener("DOMContentLoaded", () => {
      loadProducts();
    });
    document.getElementById("ProductForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const productId = parseInt(document.getElementById("productSelect").value);
      const quantity = parseInt(document.getElementById("quantity").value);

      if (isNaN(productId) || isNaN(quantity) || quantity <= 0) return;

      const productData = { productId, quantity };

      const res = await fetch(`/Order/${orderId}/AddExistingProduct`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(productData)
      });

      if (res.ok) {
        document.getElementById("ProductForm").reset();
        loadProducts();
      } else {
        alert("Failed to add product to order.");
      }
    });

    async function loadProducts() {
      let total = 0;
    const res = await fetch(`/Order/${orderId}/products`);

    if (!res.ok) {
        alert("Failed to load products");
        return;
    }

    const products = await res.json();

    const productList = document.getElementById("productList");
    productList.innerHTML = "";

    products.forEach(p => {
        total += p.price * p.quantity;
        productList.innerHTML += `
            <div class="card product-card mb-3">

                <div class="card-body">

                    <div class="row align-items-center">

                        <div class="col-md-5">

                            <h5 class="fw-bold mb-1">
                                ${p.name}
                            </h5>

                            <small class="text-muted">
                                Product
                            </small>

                        </div>

                        <div class="col-md-2 text-center">

                            <span class="badge bg-primary fs-6">
                                $${p.price.toFixed(2)}
                            </span>

                        </div>

                        <div class="col-md-2 text-center">

                            <span class="badge bg-secondary fs-6">
                                x${p.quantity}
                            </span>

                        </div>

                        <div class="col-md-2 text-center">

                            <strong class="text-success fs-5">

                                $${(p.price * p.quantity).toFixed(2)}

                            </strong>

                        </div>

                        <div class="col-md-1 text-end">

                            <button
                                class="btn btn-outline-danger"
                                onclick="deleteProduct(${p.id})">

                                <i class="bi bi-trash"></i>

                            </button>

                        </div>

                    </div>

                </div>

            </div>
        `;
    });

    document.getElementById("orderTotal").innerText =
    "$" + total.toFixed(2);

    if (products.length === 0) {

        productList.innerHTML = `
            <div class="card section-card">

                <div class="card-body text-center py-5">

                    <i class="bi bi-cart-x display-3 text-secondary"></i>

                    <h4 class="mt-3">
                        No products in this order
                    </h4>

                    <p class="text-muted">
                        Use the form above to add products.
                    </p>

                </div>

            </div>
        `;
    }
}

    async function deleteProduct(productId) {
      if (!confirm("Remove this product from order?")) return;

      const res = await fetch(`/Order/${orderId}/products/${productId}`, {
        method: "DELETE"
      });

      if (res.ok) {
        loadProducts();
      } else {
        alert("Failed to delete.");
      }
    }

    document.getElementById("saveOrderBtn").addEventListener("click", async () => {
      window.location.href = '/Home/Index'; 
    });
  </script>
}
