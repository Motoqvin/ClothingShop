@model ClothingStoreApp.Presentation.ViewModels.EditInfoViewModel
@{
    ViewData["Title"] = "Edit Info";
}

<style>
    .hero {
        background: linear-gradient(135deg, #212529, #495057);
        color: white;
        border-radius: 22px;
        padding: 3rem;
        text-align: center;
        margin-bottom: 2rem;
    }

    .hero h1 {
        font-weight: 700;
        margin-bottom: .5rem;
    }

    .profile-card {
        border: none;
        border-radius: 22px;
        box-shadow: 0 12px 35px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .profile-card .card-body {
        padding: 2.5rem;
    }

    .profile-avatar {
        width: 170px;
        height: 170px;
        object-fit: cover;
        border-radius: 50%;
        border: 5px solid white;
        box-shadow: 0 10px 25px rgba(0,0,0,.15);
        margin-top: -90px;
        background: white;
    }

    .info-row {
        padding: 14px 0;
        border-bottom: 1px solid #ececec;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: #6c757d;
        font-weight: 600;
    }

    .btn-modern {
        border-radius: 14px;
        padding: 12px;
        font-weight: 600;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
    }

    .form-control:focus {
        box-shadow: 0 0 0 .2rem rgba(13,110,253,.15);
    }

    .upload-box {
        border: 2px dashed #d5d5d5;
        border-radius: 15px;
        padding: 20px;
        background: #fafafa;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card profile-card">
                <div class="card-body">
                    <div class="hero">
                        <h1>Edit Profile</h1>
                        <p class="mb-0">
                            Update your account information.
                        </p>
                    </div>

                    <form asp-action="EditInfo" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 small mb-3"></div>

                        <div class="upload-box text-center mb-4">
                            <img src="@(string.IsNullOrEmpty(Model.CurrentAvatar)
                                ? "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS8oghbsuzggpkknQSSU-Ch_xep_9v3m6EeBQ&s"
                                : Url.Content("~/" + Model.CurrentAvatar))"
                                id="avatarPreview"
                                class="rounded-circle shadow mb-3"
                                style="width:140px;height:140px;object-fit:cover;" />
                            <div class="d-flex justify-content-center gap-2 flex-wrap mb-3">
                                <label for="Avatar" class="btn btn-dark btn-modern">
                                    <i class="bi bi-camera"></i>Change Photo
                                </label>
                                @if (!string.IsNullOrEmpty(Model.CurrentAvatar))
                                {
                                    <button type="submit"
                                            formaction="@Url.Action("DeleteAvatar")"
                                            formmethod="post"
                                            class="btn btn-outline-danger btn-modern"
                                            onclick="return confirm('Delete your avatar?')">
                                        <i class="bi bi-trash"></i>Remove
                                    </button>
                                }
                            </div>
                            <input asp-for="Avatar"
                                id="Avatar"
                                type="file"
                                accept="image/*"
                                class="d-none"
                                onchange="previewAvatar(this)" />
                            <small class="text-muted">JPG, PNG or WEBP • Max 5 MB</small>
                            <span asp-validation-for="Avatar"class="text-danger d-block mt-2"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label">Username</label>
                            <input asp-for="UserName" class="form-control" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label">Address</label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark btn-modern w-100">
                            💾 Save Changes
                        </button>
                    </form>

                    <a asp-action="MyInfo" class="btn btn-outline-secondary btn-modern w-100 mt-3">
                    ← Back to Profile
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
