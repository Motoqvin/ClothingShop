@model Product?

@if (Model != null)
{
    <form id="ProductForm" class="row g-3 needs-validation" novalidate>
        <div class="mb-3">
            <label for="name" class="form-label">Name</label>
            <input type="text" class="form-control" id="name" name="name" value="@Model.Name" required minlength="2">
            <div class="invalid-feedback">Please enter a valid product name (at least 2 characters).</div>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <input type="text" class="form-control" id="description" name="description" value="@Model.Description">
        </div>

        <div class="mb-3">
            <label for="price" class="form-label">Price</label>
            <input type="number" step="0.01" min="0.01" class="form-control" id="price" name="price" value="@Model.Price" required>
            <div class="invalid-feedback">Please enter a valid positive price.</div>
        </div>

        <button type="submit" class="btn btn-primary">Change</button>
    </form>
}
else
{
    <h1 class="text-danger">Product not found!</h1>
}


<script>
    const form = document.getElementById('ProductForm');

    form.addEventListener('submit', async function (ev) {
        ev.preventDefault();

        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }

        const name = document.getElementById('name').value;
        const description = document.getElementById('description').value;
        const price = document.getElementById('price').value;

        const data = { name, description, price };

        try {
            const response = await fetch('/Product/@Model?.Id', {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                window.history.back();
            } else {
                console.error('Server error:', response);
                alert("Failed to update the product.");
            }
        } catch (error) {
            console.error('Request failed', error);
            alert("An unexpected error occurred.");
        }
    });
</script>
