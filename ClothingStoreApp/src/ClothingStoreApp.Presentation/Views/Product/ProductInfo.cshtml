@model Product?

@{
    ViewData["Title"] = Model?.Name ?? "Product";
}

<style>
    .hero {
        background: linear-gradient(135deg,#212529,#495057);
        color: white;
        border-radius: 22px;
        padding: 2.5rem;
        margin-bottom: 2rem;
    }

    .detail-card {
        border: none;
        border-radius: 22px;
        box-shadow: 0 12px 30px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .detail-image {
        width: 100%;
        height: 100%;
        min-height: 380px;
        object-fit: cover;
    }

    .price {
        font-size: 2rem;
        font-weight: 700;
        color: #0d6efd;
    }

    .qty-input {
        width: 90px;
        border-radius: 12px;
        text-align: center;
    }

    .btn-modern {
        border-radius: 12px;
        font-weight: 600;
    }
</style>

@if (Model != null)
{
    <div class="hero">
        <h1 class="mb-0">@Model.Name</h1>
    </div>

    <div class="card detail-card">
        <div class="row g-0">
            <div class="col-md-6">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="detail-image" alt="@Model.Name"
                         onerror="this.onerror=null;this.src='https://placehold.co/600x600?text=No+Image';" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 bg-light text-muted" style="min-height:380px;">
                        <i class="bi bi-image display-3"></i>
                    </div>
                }
            </div>

            <div class="col-md-6">
                <div class="card-body p-5 d-flex flex-column h-100">

                    <h5 class="text-uppercase text-muted mb-2">Description</h5>
                    <p class="mb-4">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)
                    </p>

                    <div class="price mb-4">
                        $@Model.Price.ToString("N2")
                    </div>

                    <form asp-controller="Cart"
      asp-action="Add"
      method="post"
      class="mt-auto">

    @Html.AntiForgeryToken()

    <input type="hidden" name="id" value="@Model.Id" />
    <input type="hidden" name="name" value="@Model.Name" />
    <input type="hidden" name="price" value="@Model.Price" />

    <div class="mb-4">
        <label for="quantity" class="form-label fw-semibold">
            Quantity
        </label>

        <div class="input-group" style="max-width:180px;">

            <button type="button"
                    class="btn btn-outline-secondary"
                    onclick="changeQty(-1)">
                −
            </button>

            <input id="quantity"
                   name="quantity"
                   type="number"
                   value="1"
                   min="1"
                   class="form-control text-center" />

            <button type="button"
                    class="btn btn-outline-secondary"
                    onclick="changeQty(1)">
                +
            </button>

        </div>
    </div>

    <div class="d-grid gap-2">

        <button type="submit"
                class="btn btn-dark btn-lg btn-modern">

            <i class="bi bi-cart-plus me-2"></i>

            Add to Cart

        </button>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-outline-secondary btn-modern">

            Continue Shopping

        </a>

    </div>

</form>

                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger text-center p-5 rounded-4">
        <h4 class="mb-3">Product not found</h4>
        <a asp-controller="Home" asp-action="Index" class="btn btn-dark btn-modern">Back to Shop</a>
    </div>
}


@section Scripts{

<script>

function changeQty(change){

    const input = document.getElementById("quantity");

    let value = parseInt(input.value) || 1;

    value += change;

    if(value < 1)
        value = 1;

    input.value = value;

}

</script>

}