@{
    ViewData["Title"] = "Welcome";
    Layout = "_Layout";

    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;

    string href = isAuthenticated
        ? Url.Action("Index", "Home")!
        : Url.Action("Login", "Identity")!;
}

<style>
    .hero-section{
        background:linear-gradient(135deg,#212529,#495057);
        color:white;
        border-radius:28px;
        padding:5rem 3rem;
        overflow:hidden;
        position:relative;
    }

    .hero-section::before{
        content:"";
        position:absolute;
        width:350px;
        height:350px;
        background:rgba(255,255,255,.08);
        border-radius:50%;
        top:-120px;
        right:-80px;
    }

    .hero-section::after{
        content:"";
        position:absolute;
        width:220px;
        height:220px;
        background:rgba(255,255,255,.05);
        border-radius:50%;
        bottom:-70px;
        left:-50px;
    }

    .hero-content{
        position:relative;
        z-index:2;
    }

    .feature-card{
        border:none;
        border-radius:22px;
        overflow:hidden;
        box-shadow:0 12px 30px rgba(0,0,0,.08);
        transition:.35s;
        height:100%;
    }

    .feature-card:hover{
        transform:translateY(-10px);
        box-shadow:0 18px 40px rgba(0,0,0,.15);
    }

    .feature-card img{
        height:260px;
        object-fit:cover;
    }

    .stat-card{
        background:white;
        border-radius:18px;
        padding:1.5rem;
        box-shadow:0 8px 20px rgba(0,0,0,.08);
    }

    .cta-card{
        background:linear-gradient(135deg,#0d6efd,#3d8bfd);
        color:white;
        border-radius:24px;
        padding:3rem;
    }

    .btn-modern{
        border-radius:12px;
        padding:.9rem 2rem;
        font-weight:600;
    }
</style>

<div class="container py-5">
    <div class="hero-section mb-5">
        <div class="row align-items-center hero-content">
            <div class="col-lg-7">
                <span class="badge bg-light text-dark mb-3 px-3 py-2">✨ New Collection Available</span>
                <h1 class="display-3 fw-bold mb-4">Dress Better.<br />Feel Better.</h1>
                <p class="lead mb-4 text-light">Discover premium clothing, timeless classics, and the newest fashion trends—all in one place.</p>
                <a href="@href" class="btn btn-light btn-lg btn-modern me-3">🛍 Start Shopping</a>
            </div>
            <div class="col-lg-5 text-center">
                <img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=800&q=80"
                     class="img-fluid rounded-4 shadow-lg"
                     style="max-height:450px;object-fit:cover;">
            </div>
        </div>
    </div>
    <div class="row text-center g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card">
                <h2 class="fw-bold text-primary">1000+</h2>
                <p class="mb-0 text-muted">Happy Customers</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <h2 class="fw-bold text-success">250+</h2>
                <p class="mb-0 text-muted">Fashion Products</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <h2 class="fw-bold text-warning">24/7</h2>
                <p class="mb-0 text-muted">Customer Support</p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-4">
            <div class="card feature-card">
                <img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f?auto=format&fit=crop&w=700&q=80">
                <div class="card-body text-center">
                    <h4 class="fw-bold">👕 Trendy Styles</h4>
                    <p class="text-muted">Stay ahead with carefully selected collections inspired by the latest fashion.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card feature-card">
                <img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?auto=format&fit=crop&w=700&q=80">
                <div class="card-body text-center">
                    <h4 class="fw-bold">🌿 Premium Quality</h4>
                    <p class="text-muted">Every item is chosen for comfort, durability, and exceptional craftsmanship.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card feature-card">
                <img src="https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?auto=format&fit=crop&w=700&q=80">
                <div class="card-body text-center">
                    <h4 class="fw-bold">🚚 Fast Delivery</h4>
                    <p class="text-muted">Receive your orders quickly with reliable shipping and secure packaging.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="cta-card text-center">
        <h2 class="fw-bold mb-3">Ready to refresh your wardrobe?</h2>
        <p class="lead mb-4">Explore hundreds of products and discover your next favorite outfit.</p>
        <a href="@href" class="btn btn-light btn-lg btn-modern">Start Shopping →</a>
    </div>
</div>