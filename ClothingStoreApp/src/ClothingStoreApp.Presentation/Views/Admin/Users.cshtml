@using Microsoft.AspNetCore.Identity
@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<User>
@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "User Management";
}

<style>
    .hero {
        background: linear-gradient(135deg,#212529,#495057);
        color: white;
        border-radius: 22px;
        padding: 3rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    .section-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .user-row:hover {
        background: #f8f9fa;
        transition: .2s;
    }

    .avatar {
        width: 55px;
        height: 55px;
        object-fit: cover;
        border-radius: 50%;
        border: 3px solid #dee2e6;
    }

    .btn-modern {
        border-radius: 12px;
        font-weight: 600;
    }

    .table td,
    .table th {
        vertical-align: middle;
    }

    .badge {
        font-size: .8rem;
        padding: .55rem .8rem;
        border-radius: 30px;
    }

    .pagination .page-link{
    border-radius:10px;
    margin:0 4px;
    border:none;
    color:#212529;
    }

    .pagination .active .page-link{
        background:#212529;
        color:white;
    }

    .pagination .page-link:hover{
        background:#343a40;
        color:white;
    }
</style>

<div class="hero">
    <h1 class="fw-bold">
        <i class="bi bi-people-fill"></i>
        User Management
    </h1>

    <p class="mb-0 opacity-75">
        Manage user accounts and permissions.
    </p>
</div>

<div class="card section-card">

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="text-center py-5">

                <i class="bi bi-people display-1 text-secondary"></i>

                <h3 class="mt-3">
                    No users found
                </h3>

                <p class="text-muted">
                    There are currently no registered users.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>User</th>

                            <th>Email</th>

                            <th>Roles</th>

                            <th class="text-end">Action</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var user in Model)
                        {
                            <tr class="user-row">

                                <td>

                                    <div class="d-flex align-items-center">

                                        <img src="@(string.IsNullOrEmpty(user.Avatar)
                                            ? "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS8oghbsuzggpkknQSSU-Ch_xep_9v3m6EeBQ&s"
                                            : "/" + user.Avatar)"
                                             class="avatar me-3" />

                                        <div>

                                            <div class="fw-bold">
                                                @user.UserName
                                            </div>

                                            <small class="text-muted">
                                                ID: @user.Id.Substring(0,8)
                                            </small>

                                        </div>

                                    </div>

                                </td>

                                <td>

                                    @user.Email

                                </td>

                                <td>

                                    @foreach (var role in await UserManager.GetRolesAsync(user))
                                    {
                                        var color = role switch
                                        {
                                            "Admin" => "danger",
                                            "User" => "primary",
                                            _ => "secondary"
                                        };

                                        <span class="badge bg-@color me-1">
                                            @role
                                        </span>
                                    }

                                </td>

                                <td class="text-end">

                                    <a asp-action="EditUserRoles"
                                       asp-route-id="@user.Id"
                                       class="btn btn-outline-dark btn-modern">

                                        <i class="bi bi-pencil-square"></i>
                                        Edit Roles

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>

<div class="d-flex justify-content-center">
    @Html.PagedListPager(
        Model,
        page => Url.Action("Index", new
        {
            page,
            search = Context.Request.Query["search"].ToString()
        }),
        new PagedListRenderOptions
        {
            UlElementClasses = new[] { "pagination", "mt-4" },
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
            DisplayLinkToFirstPage = PagedListDisplayMode.Always,
            DisplayLinkToLastPage = PagedListDisplayMode.Always,
            DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
            DisplayLinkToNextPage = PagedListDisplayMode.Always,
            MaximumPageNumbersToDisplay = 5
        })
</div>