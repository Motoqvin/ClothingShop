@using Microsoft.AspNetCore.Identity
@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<User>
@inject UserManager<User> UserManager
@{
    ViewData["Title"] = "Admin - Users";
}

<h2 class="mb-4">👤 User Management</h2>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Email</th>
            <th>Username</th>
            <th>Roles</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.UserName</td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <span class="badge bg-secondary">@string.Join(", ", await UserManager.GetRolesAsync(user))</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Restricted</span>
                    }
                </td>
                <td>
                    <a asp-action="EditUserRoles" asp-route-id="@user.Id" class="btn btn-sm btn-secondary">Edit Roles</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-center">
    @Html.PagedListPager(Model, page => Url.Action("Users", 
        new { page }), options: new PagedListRenderOptions{
            UlElementClasses = new[] { "pagination", "mt-4" },
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
            DisplayLinkToFirstPage = PagedListDisplayMode.Always,
            DisplayLinkToLastPage = PagedListDisplayMode.Always,
            DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
            DisplayLinkToNextPage = PagedListDisplayMode.Always,
            MaximumPageNumbersToDisplay = 5
        })
</div>