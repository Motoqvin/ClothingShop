@model Product

@{
    ViewData["Title"] = "Create Product";
}

<style>
.hero{
    background:linear-gradient(135deg,#212529,#495057);
    color:white;
    border-radius:22px;
    padding:3rem;
    text-align:center;
    margin-bottom:2rem;
}

.section-card{
    border:none;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.preview-card{
    border:none;
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.preview-card img{
    height:320px;
    object-fit:cover;
}

.btn-modern{
    border-radius:12px;
    font-weight:600;
}

.form-control,
textarea{
    border-radius:12px;
}

.input-group-text{
    border-radius:12px 0 0 12px;
}
</style>

<div class="hero">

    <h1>

        <i class="bi bi-plus-circle-fill"></i>

        Create Product

    </h1>

    <p class="mb-0 opacity-75">

        Add a new product to your clothing store.

    </p>

</div>

<div class="row g-4">

    <div class="col-lg-7">

        <div class="card section-card">

            <div class="card-body p-5">

                <form asp-action="CreateProduct" method="post" enctype="multipart/form-data">

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"></div>

                    <div class="mb-4">

                        <label asp-for="Name"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Name"
                               id="productName"
                               class="form-control"
                               placeholder="Classic Denim Jacket">

                        <span asp-validation-for="Name"
                              class="text-danger"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Price"
                               class="form-label fw-semibold"></label>

                        <div class="input-group">

                            <span class="input-group-text">$</span>

                            <input asp-for="Price"
                                   id="productPrice"
                                   class="form-control"
                                   placeholder="49.99">

                        </div>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Description"
                               class="form-label fw-semibold"></label>

                        <textarea asp-for="Description"
                                  id="productDescription"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Describe the product..."></textarea>

                    </div>

                    <div class="mb-4">

                        <label for="productImage"
                               class="form-label fw-semibold">Product Photo</label>

                        <input type="file"
                               name="ImageFile"
                               id="productImage"
                               class="form-control"
                               accept="image/*"
                               onchange="previewImage()">

                        <div class="form-text">Upload a JPG or PNG image from your device.</div>

                    </div>

                    <div class="d-flex gap-3">

                        <button class="btn btn-dark btn-modern px-4">

                            <i class="bi bi-check-circle"></i>

                            Create Product

                        </button>

                        <a asp-action="Products"
                           class="btn btn-outline-secondary btn-modern">

                            Cancel

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <div class="col-lg-5">

        <div class="card preview-card sticky-top"
             style="top:20px;">

            <img id="previewImage"
                 src="https://via.placeholder.com/500x500?text=Product"
                 class="card-img-top">

            <div class="card-body">

                <h3 id="previewName">

                    Product Name

                </h3>

                <p id="previewDescription"
                   class="text-muted">

                    Product description will appear here.

                </p>

                <h2 class="text-success">

                    $<span id="previewPrice">0.00</span>

                </h2>

                <button class="btn btn-dark w-100 btn-modern mt-3"
                        disabled>

                    <i class="bi bi-cart-plus"></i>

                    Add to Cart

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts{

<partial name="_ValidationScriptsPartial"/>

<script>

const nameInput=document.getElementById("productName");
const descInput=document.getElementById("productDescription");
const priceInput=document.getElementById("productPrice");
const imageInput=document.getElementById("productImage");

nameInput.oninput=()=>{

document.getElementById("previewName").innerText=
nameInput.value||"Product Name";

}

descInput.oninput=()=>{

document.getElementById("previewDescription").innerText=
descInput.value||"Product description will appear here.";

}

priceInput.oninput=()=>{

document.getElementById("previewPrice").innerText=
priceInput.value||"0.00";

}

function previewImage(){

const file = imageInput.files && imageInput.files[0];

if (file) {
    const reader = new FileReader();
    reader.onload = function(e){
        document.getElementById("previewImage").src = e.target.result;
    };
    reader.readAsDataURL(file);
} else {
    document.getElementById("previewImage").src =
    "https://via.placeholder.com/500x500?text=Product";
}

}

</script>

}