@model Product
@{
    ViewData["Title"] = "Create Product";
}

<div class="mb-4">
    <a asp-action="Products" class="text-decoration-none text-muted small">
        <i class="bi bi-arrow-left me-1"></i>Back to Products
    </a>
    <h2 class="mt-2 mb-0">🆕 Create New Product</h2>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                <form asp-action="CreateProduct" method="post" class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Classic Denim Jacket" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Short description shown to customers"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="ImageUrl" class="form-label fw-semibold"></label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg"
                               oninput="previewImage(this.value, 'createPreview')" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        <div class="mt-3 border rounded-3 bg-light d-flex align-items-center justify-content-center overflow-hidden"
                             style="height: 180px; width: 240px;">
                            <img id="createPreview" src="" alt="Preview" class="w-100 h-100 d-none" style="object-fit: cover;" />
                            <span id="createPreviewPlaceholder" class="text-muted small"><i class="bi bi-image fs-3 d-block text-center mb-1"></i>Image preview</span>
                        </div>
                    </div>
                    <div class="col-12 d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-3 px-4">
                            <i class="bi bi-check-lg me-1"></i>Create Product
                        </button>
                        <a asp-action="Products" class="btn btn-outline-secondary rounded-3 px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(url, imgId) {
            const img = document.getElementById(imgId);
            const placeholder = document.getElementById(imgId + 'Placeholder');
            if (!url) {
                img.classList.add('d-none');
                placeholder.classList.remove('d-none');
                return;
            }
            img.onload = function () {
                img.classList.remove('d-none');
                placeholder.classList.add('d-none');
            };
            img.onerror = function () {
                img.classList.add('d-none');
                placeholder.classList.remove('d-none');
            };
            img.src = url;
        }
    </script>
}
