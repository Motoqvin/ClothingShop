@model List<Order>

@{
    ViewData["Title"] = "Order Management";
}

<style>
    .hero {
        background: linear-gradient(135deg,#212529,#495057);
        color: white;
        border-radius: 22px;
        padding: 3rem;
        text-align: center;
        margin-bottom: 2rem;
    }

    .section-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .order-row {
        transition: .2s;
    }

    .order-row:hover {
        background: #f8f9fa;
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #212529;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .btn-modern {
        border-radius: 12px;
        font-weight: 600;
    }

    .price {
        font-size: 1.1rem;
        font-weight: 700;
        color: #198754;
    }

    .table td,
    .table th {
        vertical-align: middle;
    }
</style>

<div class="hero">

    <h1 class="fw-bold">
        <i class="bi bi-receipt-cutoff"></i>
        Order Management
    </h1>

    <p class="mb-0 opacity-75">
        View and manage all customer orders.
    </p>

</div>

<div class="card section-card">

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="text-center py-5">

                <i class="bi bi-bag-x display-1 text-secondary"></i>

                <h3 class="mt-3">
                    No orders found
                </h3>

                <p class="text-muted">
                    Orders will appear here after customers make purchases.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Order</th>

                            <th>Customer</th>

                            <th>Date</th>

                            <th>Total</th>

                            <th></th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var order in Model)
                        {
                            <tr class="order-row">

                                <td>

                                    <div class="d-flex align-items-center">

                                        <div class="icon-circle me-3">

                                            <i class="bi bi-bag-fill"></i>

                                        </div>

                                        <div>

                                            <div class="fw-bold">

                                                #@order.Id

                                            </div>

                                            <small class="text-muted">

                                                Order

                                            </small>

                                        </div>

                                    </div>

                                </td>

                                <td>

                                    <span class="fw-semibold">

                                        @order.UserId

                                    </span>

                                </td>

                                <td>

                                    @order.Date.ToString("dd MMM yyyy")

                                    <br>

                                    <small class="text-muted">

                                        @order.Date.ToString("HH:mm")

                                    </small>

                                </td>

                                <td>

                                    <span class="price">

                                        $@order.TotalPrice.ToString("N2")

                                    </span>

                                </td>

                                <td class="text-end">

                                    <a asp-controller="Admin"
                                       asp-action="OrderDetails"
                                       asp-route-id="@order.Id"
                                       class="btn btn-outline-dark btn-modern">

                                        <i class="bi bi-eye"></i>

                                        View

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>