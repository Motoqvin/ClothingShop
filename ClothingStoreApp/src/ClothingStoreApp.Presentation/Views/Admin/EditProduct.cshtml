@model Product
@{
    ViewData["Title"] = "Edit Product";
}

<style>
.hero{
    background:linear-gradient(135deg,#212529,#495057);
    color:white;
    border-radius:22px;
    padding:3rem;
    text-align:center;
    margin-bottom:2rem;
}

.section-card{
    border:none;
    border-radius:22px;
    box-shadow:0 12px 30px rgba(0,0,0,.08);
}

.preview-card{
    border:none;
    border-radius:20px;
    box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.preview-image{
    width:100%;
    height:300px;
    object-fit:cover;
    border-radius:16px;
}

.form-control,
.input-group-text{
    border-radius:12px;
}

.btn-modern{
    border-radius:12px;
    font-weight:600;
}
</style>

<div class="hero">

    <h1>
        <i class="bi bi-pencil-square"></i>
        Edit Product
    </h1>

    <p class="mb-0 text-white-50">
        Update product information and preview changes instantly.
    </p>

</div>

<div class="row g-4">

    <div class="col-lg-8">

        <div class="card section-card">

            <div class="card-body p-5">

                <form asp-action="EditProduct" method="post" enctype="multipart/form-data">

                    <input asp-for="Id" type="hidden"/>

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"></div>

                    <div class="mb-4">

                        <label asp-for="Name"
                               class="form-label fw-bold"></label>

                        <input asp-for="Name"
                               class="form-control form-control-lg"/>

                        <span asp-validation-for="Name"
                              class="text-danger"></span>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label asp-for="Price"
                                   class="form-label fw-bold"></label>

                            <div class="input-group">

                                <span class="input-group-text">$</span>

                                <input asp-for="Price"
                                       class="form-control"/>

                            </div>

                            <span asp-validation-for="Price"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Description"
                               class="form-label fw-bold"></label>

                        <textarea asp-for="Description"
                                  rows="5"
                                  class="form-control"></textarea>

                    </div>

                    <div class="mb-4">

                        <label for="productImage"
                               class="form-label fw-bold">Product Photo</label>

                        <input type="file"
                               name="ImageFile"
                               id="productImage"
                               class="form-control"
                               accept="image/*"
                               onchange="previewSelectedFile(this)" />

                        <div class="form-text">Leave empty to keep the current photo.</div>

                    </div>

                    <div class="d-flex gap-3">

                        <button class="btn btn-success btn-lg btn-modern">

                            <i class="bi bi-check-circle"></i>

                            Save Changes

                        </button>

                        <a asp-action="Products"
                           class="btn btn-outline-secondary btn-lg btn-modern">

                            Cancel

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <div class="col-lg-4">

        <div class="card preview-card sticky-top"
             style="top:20px;">

            <div class="card-body">

                <h4 class="mb-4">

                    Live Preview

                </h4>

                <img id="previewImage"
                     src="@Model.ImageUrl"
                     class="preview-image"/>

                <div class="mt-4">

                    <h3 id="previewTitle">

                        @Model.Name

                    </h3>

                    <h4 class="text-primary">

                        $<span id="previewPrice">
                            @Model.Price
                        </span>

                    </h4>

                    <p id="previewDescription"
                       class="text-muted">

                        @Model.Description

                    </p>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts{

<partial name="_ValidationScriptsPartial"/>

<script>

function previewSelectedFile(input){
    const file = input.files && input.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e){
        document.getElementById("previewImage").src = e.target.result;
    };
    reader.readAsDataURL(file);
}

document.querySelector("[name='Name']").addEventListener("input",e=>{
    document.getElementById("previewTitle").innerText=e.target.value;
});

document.querySelector("[name='Price']").addEventListener("input",e=>{
    document.getElementById("previewPrice").innerText=e.target.value;
});

document.querySelector("[name='Description']").addEventListener("input",e=>{
    document.getElementById("previewDescription").innerText=e.target.value;
});

</script>

}