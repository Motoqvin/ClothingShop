@using ClothingStoreApp.Presentation.ViewModels
@model EditUserRolesViewModel

<h2>Edit Roles for @Model.Email</h2>
<form asp-action="EditUserRoles" method="post">
    <input type="hidden" asp-for="UserId" />
    @for (int i = 0; i < Model.AvailableRoles.Count; i++)
    {
        <div class="form-check">
            <input class="form-check-input" type="checkbox"
                   name="SelectedRoles"
                   value="@Model.AvailableRoles[i]"
                   @(Model.SelectedRoles.Contains(Model.AvailableRoles[i]) ? "checked" : "") />
            <label class="form-check-label">@Model.AvailableRoles[i]</label>
        </div>
    }
    <button type="submit" class="btn btn-primary mt-3">Save Roles</button>
</form>