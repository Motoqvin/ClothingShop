@model List<Product>
@{
    ViewData["Title"] = "Admin - Products";
}

<h2 class="mb-4">📦 Product Management</h2>
<a class="btn btn-primary mb-3" asp-action="CreateProduct">Add New Product</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.Description</td>
                <td>$@product.Price</td>
                <td>
                    <a asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="DeleteProduct" asp-route-id="@product.Id" method="post" style="display:inline">
                        <button class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>