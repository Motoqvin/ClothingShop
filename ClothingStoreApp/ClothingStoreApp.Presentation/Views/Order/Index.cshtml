@inject IOrdersRepository ordersRepository
@using System.Security.Claims

@{
    ViewData["Title"] = "Your Orders";

    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var orders = ordersRepository.GetAll(userId ?? string.Empty);
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📦 Your Orders</h2>
        <a class="btn btn-success btn-lg" href="Order/Create">
            <i class="bi bi-plus-circle"></i> Create New Order
        </a>
    </div>

    @if (!orders.Any())
    {
        <div class="alert alert-warning text-center">
            <i class="bi bi-inbox"></i> You haven't placed any orders yet.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Order ID</th>
                                <th>Date</th>
                                <th>Total Price</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var order in orders)
                        {
                            <tr>
                                <td>
                                    <a href="Order/@order.Id" class="text-decoration-none">
                                        #@order.Id
                                    </a>
                                </td>
                                <td>@order.Date.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>$@order.TotalPrice</td>
                                <td>
                                    <button class="btn btn-outline-danger btn-sm" onclick="DeleteOrder(@order.Id)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<script>
    function DeleteOrder(orderId) {
        if (!confirm("Are you sure you want to delete this order?")) return;

        fetch(`/Order/${orderId}`, {
            method: 'DELETE'
        })
        .then(response => {
            if (response.ok) {
                window.location.reload();
            } else {
                alert("Failed to delete order.");
            }
        });
    }
</script>
